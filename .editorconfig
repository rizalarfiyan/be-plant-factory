# top-most EditorConfig file
root = true

# Global settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Specific settings for Go source files
[*.go]
indent_style = tab
indent_size = 4

# Specific settings for Go modules and work files
[go.{mod,work}]
indent_style = tab

# Yaml files should use 2 spaces for indentation
[*.yaml]
indent_style = space
indent_size = 2
